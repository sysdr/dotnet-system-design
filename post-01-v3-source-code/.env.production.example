# .env.production.example — Post 1
# Connection strings for REAL Azure resources (no subscription needed for local dev).
# Retrieve the real values with Azure CLI after deploying infra/main.bicep.
#
# Azure Monitor / Application Insights:
#   az monitor app-insights component show \
#     --app hyperscale-log-monitoring \
#     --resource-group rg-hyperscale \
#     --query connectionString -o tsv
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://eastus.in.applicationinsights.azure.com/

# Post 9+ — Azure Service Bus:
# AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;...

# Post 12+ — Azure Event Hubs:
# AZURE_EVENT_HUBS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;...
